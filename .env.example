# ===== REQUIRED: Set these before deploying =====
# Generate a strong JWT secret: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# GitHub OAuth: Create at https://github.com/settings/developers
# Callback URL: https://<YOUR_DOMAIN>/api/v1/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# MinIO credentials (internal object storage)
MINIO_ACCESS_KEY=change-me-minio-access
MINIO_SECRET_KEY=change-me-minio-secret

# PostgreSQL connection (internal, no need to change unless you want to)
DATABASE_URL=postgres://svguser:svgpass@postgres:5432/svgconverter?sslmode=disable

# ===== Infrastructure (no need to change) =====
REDIS_ADDR=redis:6379
MINIO_ENDPOINT=minio:9000
PORT=8080
MAX_FILE_SIZE=10485760

# ===== Domain and HTTPS =====
# Set this to your domain for HTTPS (Let's Encrypt auto-provisioned by Caddy)
DOMAIN=svg.yourdomain.com

# Frontend URL (used for CORS and OAuth redirects)
FRONTEND_URL=https://svg.yourdomain.com

# ===== PostgreSQL (for docker-compose, no need to change) =====
POSTGRES_USER=svguser
POSTGRES_PASSWORD=svgpass
POSTGRES_DB=svgconverter
